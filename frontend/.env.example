# =====================================================================
# Frontend environment variables (Vite).
#
# Copy to ".env" for local dev. Vite only exposes vars prefixed VITE_.
# ".env" is git-ignored - do not commit it.
#
# NOTE: nothing secret lives here. The OAuth client_secret stays on the
# backend ONLY. The client_id is public by design (it travels in the
# browser redirect anyway).
# =====================================================================

# Base URL of the Spring Boot backend.
#   local dev  -> http://localhost:8080
#   production -> https://<your-app>.onrender.com
VITE_API_BASE_URL=http://localhost:8080

# AIESEC OAuth client_id (public). From your developer application.
VITE_AIESEC_CLIENT_ID=<client_id>

# AIESEC OAuth authorize endpoint.
#   staging    -> https://auth-staging.aiesec.org/oauth/authorize
#   production -> https://auth.aiesec.org/oauth/authorize
VITE_AIESEC_AUTHORIZE_URL=https://auth-staging.aiesec.org/oauth/authorize

# Redirect URI - MUST exactly match what is registered on the
# developer application (trailing slash, path, everything).
VITE_AIESEC_REDIRECT_URI=http://localhost:5173/auth/callback
