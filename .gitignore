# =====================================================================
# Root .gitignore for the monorepo.
# Each subproject (backend/, frontend/) also has its own .gitignore;
# this is a safety net so secrets and build output never get committed
# regardless of which directory you run git from.
# =====================================================================

# --- Secrets: NEVER commit ---
.env
.env.local
*.env
!.env.example

# --- Backend build output (Maven) ---
target/

# --- Frontend build output / deps (Node) ---
node_modules/
dist/

# --- Logs ---
*.log
npm-debug.log*

# --- IDE / editors ---
.idea/
*.iml
.vscode/
.settings/
.project
.classpath

# --- OS ---
.DS_Store
Thumbs.db
