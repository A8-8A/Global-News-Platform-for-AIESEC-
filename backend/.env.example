# =====================================================================
# Environment variables for the AIESEC News backend.
#
# Copy this file to ".env" for local development and fill in real
# values. ".env" is git-ignored - NEVER commit real secrets.
#
# On Render, set these in the dashboard (Environment tab) instead.
# =====================================================================

# ---- Spring profile ----
# Local dev: staging (default).  Render: prod.
SPRING_PROFILES_ACTIVE=staging

# ---- Neon Postgres ----
# From the Neon dashboard connection string. Use the pooled connection.
DATABASE_URL=jdbc:postgresql://<host>.neon.tech/<db>?sslmode=require
DATABASE_USERNAME=<neon_user>
DATABASE_PASSWORD=<neon_password>

# ---- AIESEC OAuth application ----
# LOCAL/staging: credentials from the developer app created in EXPA STAGING.
# RENDER/prod:   credentials from the PRODUCTION developer app (auth.aiesec.org).
# These are two different apps with two different credential pairs.
AIESEC_CLIENT_ID=<client_id>
AIESEC_CLIENT_SECRET=<client_secret>

# Must EXACTLY match a redirect URI registered on the developer app
# (trailing slash, path - everything).
AIESEC_REDIRECT_URI=https://aiesec-news.web.app/auth/callback

# ---- Our own JWT signing secret ----
# Signs the session tokens this backend issues. Any long random string.
# Generate one with:  openssl rand -base64 48
APP_JWT_SECRET=<long_random_string>
# Optional - session lifetime in ms (default 24h).
# APP_JWT_EXPIRATION_MS=86400000

# ---- Initial admin account ----
# Admins are not AIESEC users, so the first one is seeded on startup.
# If both are set and no admin with this email exists, one is created
# with a BCrypt-hashed password. Idempotent - safe to leave set.
ADMIN_SEED_EMAIL=admin@example.com
ADMIN_SEED_PASSWORD=<choose_a_strong_password>

# ---- CORS ----
# Comma-separated frontend origins allowed to call this API.
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://aiesec-news.web.app

# ---- Server ----
# Render injects PORT automatically; only set locally if you want a
# non-default port.
# PORT=8080
